# Copy this file to .env and fill in your values
# Never commit .env to git

# ── ElevenLabs (Text-to-Speech) ──────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL=eleven_turbo_v2_5               # fast + cheap model

# Per-build voice IDs (optional — defaults to free ElevenLabs voices)
# Get voice IDs from: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_TITAN=pNInz6obpgDQGcFmaJgB     # Adam  (deep, powerful)
ELEVENLABS_VOICE_ORACLE=ErXwobaYiN019PkySvjV    # Antoni (clear, measured)
ELEVENLABS_VOICE_PHANTOM=VR6AewLTigWG4xSOukaG   # Arnold (energetic)
ELEVENLABS_VOICE_SAGE=EXAVITQu4vr4xnSDxMaL      # Bella  (calm, warm)
ELEVENLABS_VOICE_MUSE=ThT5KcBeYPX3keUQqHPh      # Dorothy (bright)
ELEVENLABS_VOICE_EMPIRE=TxGEqnHWrfWFTfGW9XjX    # Josh   (authoritative)
ELEVENLABS_VOICE_GG=yoZ06aMxZJJ28mfd3POQ        # Sam    (casual, hype)

# ── Speech-to-Text (Whisper — local, no API key needed) ──────────────
WHISPER_MODEL=base                               # base | small | medium | large

# ── HuggingFace ──────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here             # needed for gated models

# ── App Config ───────────────────────────────────────────────────────
APP_ENV=development                              # development | production
SECRET_KEY=change_this_to_a_random_string

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./levelup.db    # dev: SQLite

# ── Text Model ───────────────────────────────────────────────────────
LEVELUP_BASE_MODEL=unsloth/Llama-3.2-3B-Instruct
LEVELUP_ADAPTER=./models/final/levelup-qlora-cloud
LEVELUP_LOAD_MODEL=true

# ── Vision Model (Qwen2.5-VL-7B) ─────────────────────────────────────
LEVELUP_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
LEVELUP_LOAD_VISION=false                        # set true to load vision model (~8GB VRAM)
