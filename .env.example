# Copy this file to .env and fill in your values
# Never commit .env to git

# ── ElevenLabs (Text-to-Speech) ──────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_custom_voice_id_here    # companion character voice

# ── HuggingFace ──────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here             # needed for LLaMA 3 access

# ── App Config ───────────────────────────────────────────────────────
APP_ENV=development                              # development | production
SECRET_KEY=change_this_to_a_random_string

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./levelup.db    # dev: SQLite

# ── Model Paths ──────────────────────────────────────────────────────
BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct  # or google/gemma-7b-it
FINETUNED_MODEL_PATH=./models/levelup-companion-v1
